---
import Default from '@astrojs/starlight/components/Head.astro';

// Per-page social card: /og/<slug>.png (generated by scripts/gen-og.mjs), absolute URL.
const known = [
  'philosophy', 'invariants', 'foundations', 'safety', 'self-description',
  'economy', 'auth', 'antipatterns', 'conformance', 'badge', 'adopters', 'evolution', 'prior-art',
];
// Astro 7 content-layer entries expose `id` (not `slug`); fall back across both.
const sr = Astro.locals.starlightRoute;
const slug = sr?.id ?? sr?.slug ?? sr?.entry?.id ?? sr?.entry?.slug ?? '';
const name = known.includes(slug) ? slug : 'default';
const ogImage = new URL(`/og/${name}.png`, Astro.site).href;
---

<Default><slot /></Default>
{/* Starlight already emits twitter:card=summary_large_image; we add only the images. */}
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta name="twitter:image" content={ogImage} />
